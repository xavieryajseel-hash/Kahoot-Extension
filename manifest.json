{
  "manifest_version": 3,
  "name": "Kahoot Extension",
  "version": "3.0.0",
  "description": "Kahoot Extension - Auto answer and highlight correct answers",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [],
  "host_permissions": [
    "https://kahoot.it/*",
    "https://damp-leaf-16aa.johnwee.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://kahoot.it/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}